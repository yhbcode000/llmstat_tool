# LLMStat — Calibrated LLM Estimator for Human-Subject Research
#
# Docker-based localai API (default) with OpenAI API fallback.
#
# Copy this file to .env and fill in your values.

# --- LLM Backend Selection ---
# "localai" or "openai"
LLMSTAT_BACKEND=localai

# --- LocalAI (Docker) ---
LOCALAI_BASE_URL=http://localhost:8080/v1
LOCALAI_MODEL=llama-3.2-3b-instruct
LOCALAI_API_KEY=not-needed

# --- OpenAI (fallback) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Study Defaults ---
DEFAULT_CONDITIONS=2
DEFAULT_ALPHA=0.05
DEFAULT_EQUIVALENCE_MARGIN=0.02
DEFAULT_MIN_EFFECT=0.05
